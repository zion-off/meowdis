{
  "name": "meowdis-storage",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "lint": "prettier --write --log-level warn src && eslint src --ext .ts --fix --quiet",
    "test": "vitest run --reporter=verbose"
  },
  "cloudflare": {
    "bindings": {
      "STORAGE_SECRET": {
        "description": "Secret used to authenticate requests between the compute service and the durable object. Optional if you're deploying both to Cloudflare."
      }
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.0.0",
    "wrangler": "^3.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "prettier": "^3.2.5",
    "eslint-config-prettier": "^9.1.0",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.16.1+sha512.0e155aa2629db8672b49e8475da6226aa4bdea85fdcdfdc15350874946d4f3c91faaf64cbdc4a5d1ab8002f473d5c3fcedcd197989cf0390f9badd3c04678706"
}
